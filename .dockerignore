# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Symfony cache and logs (will be generated inside container)
var/cache/*
var/log/*
!var/cache/.gitkeep
!var/log/.gitkeep

# Vendor (installed inside container)
vendor/

# Environment files (use docker-compose environment instead)
.env.local
.env.*.local

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/

# Tests coverage
coverage/
.phpunit.result.cache
